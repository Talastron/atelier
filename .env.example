# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit it.

# ─── Firebase ──────────────────────────────────────────────────────────────
# 1. Create a Firebase project at https://console.firebase.google.com
# 2. Enable Authentication → Sign-in method → Google
# 3. Enable Firestore Database (Native mode)
# 4. Project settings → General → Your apps → Add web app → copy the config
#
# These VITE_* values are baked into the public client bundle — they are NOT
# secrets. Security comes from your Firestore rules + App Check.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Owners ────────────────────────────────────────────────────────────────
# Comma-separated list of Google account emails with owner-level access.
# Owners can invite/revoke other users from inside the app.
# MUST match the email list in firestore.rules (search "EDIT THIS LIST").
VITE_OWNER_EMAILS=you@example.com

# ─── App Check / reCAPTCHA v3 ──────────────────────────────────────────────
# Required for AI features. App Check verifies requests come from your real
# app — without it, Firebase AI Logic calls are blocked.
# 1. Firebase Console → App Check → Get started → Register web app
# 2. Choose reCAPTCHA v3 → either use the auto-generated site key shown,
#    or create your own at https://www.google.com/recaptcha/admin
# 3. Paste the SITE KEY (the public one) below. Do not use the secret key.
VITE_RECAPTCHA_SITE_KEY=

# ─── Firebase AI Logic ─────────────────────────────────────────────────────
# No env var needed — but you MUST enable AI Logic in the Firebase Console:
# Firebase Console → Build → AI Logic → Get started → choose
# "Gemini Developer API" (free tier).
# Once enabled, all 9 AI features in the app work via the SDK with no API
# key in the bundle. App Check (above) gates access automatically.
