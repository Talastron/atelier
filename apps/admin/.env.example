# Atelier admin — env vars
#
# Copy this file to .env.local and fill in. Values come from the same
# Firebase project as the wardrobe app (my-digital-wardrobe-444d0).
#
# For Cloudflare Pages, set these in the project's "Environment variables"
# settings — both Production and Preview environments.

# Firebase project config — same project as the wardrobe app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID=my-digital-wardrobe-444d0
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Owner emails — comma-separated, used to gate access to the admin UI.
# Anyone not in this list will see "access denied" after sign-in.
# Must match the isOwner() helper in firestore.rules to be useful.
VITE_OWNER_EMAILS=sibylle.sherwood@gmail.com,martin.sherwood@gmail.com
