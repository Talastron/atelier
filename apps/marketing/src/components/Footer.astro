---
// apps/marketing/src/components/Footer.astro
//
// The closing chapter. Treated as the back cover of a book: a signature
// artifact (the armoire sketch) on one side, the colophon on the other.
//
// Structure — three quiet movements:
//   1. Masthead row — brand block + three nav columns + signature artifact
//   2. Brass-rule divider
//   3. Colophon — copyright + UK Companies Act 2006 statutory disclosure
//
// The signature artifact is the equivalent of Chanel's rue Cambon sketch:
// a hand-drawn-style line illustration that gives the brand a "spiritual
// home." For Atelier — a digital wardrobe — that home is the wardrobe
// itself, rendered as a French armoire with doors slightly ajar. The
// SVG below is a tasteful placeholder; eventual replacement with an
// illustrator-drawn version should swap only the <svg> markup, leaving
// the layout, address line, and surrounding chrome intact.
//
// Address line ("The Long Barn · Cobham · Surrey") uses Atelier's real
// registered office in frontispiece form — three units of increasing
// geography. The full statutory address (with postcode + Companies Act
// disclosures) lives quietly in the colophon below.
import { AtelierMark } from '@atelier/ui';
import { EDIT_URL, SITE } from '../config.ts';

const year = new Date().getFullYear();

const sections = [
  {
    eyebrow: 'The House',
    links: [
      { label: 'About', href: '/about' },
      { label: 'Journal', href: '/journal' },
      { label: 'Pricing', href: '/pricing' },
    ],
  },
  {
    eyebrow: 'The Studio',
    links: [
      { label: 'Sign In', href: EDIT_URL },
      { label: 'Open Studio', href: EDIT_URL },
      { label: 'Manage subscription', href: 'https://myatelier.lemonsqueezy.com/billing', external: true },
    ],
  },
  {
    eyebrow: 'Support',
    links: [
      { label: SITE.supportEmail, href: `mailto:${SITE.supportEmail}` },
      { label: 'Privacy', href: '/legal/privacy' },
      { label: 'Terms', href: '/legal/terms' },
    ],
  },
];
---

<footer
  class="border-t border-stone-200/60"
  style="background: var(--atelier-cream);"
>
  <div
    class="mx-auto"
    style="max-width: var(--atelier-container-max); padding-inline: var(--atelier-page-padding);"
  >
    {/* ── Movement 1: Masthead + Navigation + Signature ───────────────── */}
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-x-10 gap-y-14 lg:gap-x-12"
      style="padding-top: clamp(4rem, 7vw, 6rem); padding-bottom: clamp(2.5rem, 5vw, 4rem);"
    >
      {/* ── Brand block (lg: 3 cols) ─────────────────────────────────── */}
      <div class="lg:col-span-3" style="max-width: 30ch;">
        <a href="/" class="inline-flex items-center gap-3 group">
          <AtelierMark size={44} client:load />
          <span
            class="text-[1.625rem] tracking-tight transition-colors group-hover:text-stone-700"
            style="font-family: var(--atelier-font-display); color: var(--atelier-stone-900); letter-spacing: -0.005em;"
          >
            Atelier.
          </span>
        </a>
        <p
          class="mt-5"
          style="color: var(--atelier-stone-500); font-size: 0.9375rem; line-height: 1.6;"
        >
          Quiet luxury for your wardrobe.
        </p>
        <div class="flex items-center gap-3 mt-7">
          <span
            aria-hidden="true"
            style="display: inline-block; width: 24px; height: 1.5px; background: var(--atelier-brass-300);"
          />
          <p
            class="text-[10px] uppercase font-medium"
            style="letter-spacing: 0.28em; color: var(--atelier-stone-500);"
          >
            Volume I &middot; MMXXVI
          </p>
        </div>
      </div>

      {/* ── Navigation (lg: 6 cols, 3×2 internal) ────────────────────── */}
      <nav
        class="lg:col-span-6 grid grid-cols-1 sm:grid-cols-3 gap-8 sm:gap-10 lg:gap-12"
        aria-label="Footer navigation"
      >
        {sections.map((section) => (
          <div>
            <h3
              class="mb-5 text-[10px] uppercase font-semibold"
              style="letter-spacing: var(--atelier-tracking-eyebrow); color: var(--atelier-stone-900);"
            >
              {section.eyebrow}
            </h3>
            <ul class="flex flex-col gap-3">
              {section.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                    class="footer-link text-sm"
                    style="line-height: 1.5;"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>

      {/* ── Signature artifact (lg: 3 cols) ──────────────────────────────
           The armoire — Atelier's spiritual home, rendered as a hand-drawn
           line illustration. Replaceable with a commissioned illustrator
           drawing later; the layout below assumes ~140px wide × 220px tall.
           On mobile, sits centered as a closing flourish. On desktop, sits
           right-aligned as a signature seal. */}
      <div
        class="lg:col-span-3 flex flex-col items-center lg:items-end gap-4"
      >
        {/* Armoire SVG — Regency cabinetmaker, perfectly symmetrical, doors
            closed. Reads as an heirloom piece from a Sotheby's catalogue
            rather than a sketch in a notebook. Brass appears only on the
            metalwork (escutcheons + ring pulls) so it catches the eye
            against the otherwise grey-stone line work.

            Composition (top to bottom):
              - Urn finial centred on a serpentine swan-neck pediment
              - Dentil-moulded cornice (multiple parallel lines for layered
                shadow)
              - Two tall doors, each with two raised cartouche panels
              - Beaded edge around each door (extra inset line)
              - Brass escutcheon and ring pull at the dividing rail
              - Stepped plinth with apron moulding
              - Bracket feet at the four corners
              - Single hairline floor shadow */}
        <svg
          width="156"
          height="270"
          viewBox="0 0 160 280"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          style="display: block;"
        >
          {/* ── Pediment ─────────────────────────────────────────────── */}
          {/* Urn finial — sits centred on the broken pediment */}
          <g stroke="var(--atelier-stone-700)" stroke-width="0.7" fill="none" stroke-linecap="round">
            <path d="M 77 4 Q 80 1 83 4" />
            <line x1="80" y1="4" x2="80" y2="8" />
            <ellipse cx="80" cy="11" rx="3.5" ry="2" />
            <path d="M 76.5 12 Q 80 22 83.5 12" />
            <line x1="76" y1="22" x2="84" y2="22" />
          </g>

          {/* Swan-neck pediment — two scrolled curves meeting at the finial */}
          <path
            d="M 16 36 Q 18 24 38 22 Q 60 20 76 22"
            fill="none"
            stroke="var(--atelier-stone-700)"
            stroke-width="1.1"
            stroke-linecap="round"
          />
          <path
            d="M 144 36 Q 142 24 122 22 Q 100 20 84 22"
            fill="none"
            stroke="var(--atelier-stone-700)"
            stroke-width="1.1"
            stroke-linecap="round"
          />
          {/* Pediment inner echo — the second parallel line for depth */}
          <path
            d="M 22 36 Q 24 28 40 26 Q 60 24 76 26"
            fill="none"
            stroke="var(--atelier-stone-400)"
            stroke-width="0.6"
            stroke-linecap="round"
          />
          <path
            d="M 138 36 Q 136 28 120 26 Q 100 24 84 26"
            fill="none"
            stroke="var(--atelier-stone-400)"
            stroke-width="0.6"
            stroke-linecap="round"
          />

          {/* ── Cornice ──────────────────────────────────────────────── */}
          {/* Stacked horizontal mouldings: each line adds visual weight */}
          <line x1="14" y1="38" x2="146" y2="38" stroke="var(--atelier-stone-700)" stroke-width="1.1" stroke-linecap="round" />
          <line x1="16" y1="41" x2="144" y2="41" stroke="var(--atelier-stone-500)" stroke-width="0.7" />
          <line x1="14" y1="46" x2="146" y2="46" stroke="var(--atelier-stone-700)" stroke-width="0.9" />

          {/* Dentil moulding — small repeating teeth, the signature of
              neoclassical cabinetry. Eight dentils across, evenly spaced. */}
          <g fill="var(--atelier-stone-600)">
            <rect x="22" y="48" width="4" height="3" />
            <rect x="34" y="48" width="4" height="3" />
            <rect x="46" y="48" width="4" height="3" />
            <rect x="58" y="48" width="4" height="3" />
            <rect x="70" y="48" width="4" height="3" />
            <rect x="86" y="48" width="4" height="3" />
            <rect x="98" y="48" width="4" height="3" />
            <rect x="110" y="48" width="4" height="3" />
            <rect x="122" y="48" width="4" height="3" />
            <rect x="134" y="48" width="4" height="3" />
          </g>
          <line x1="14" y1="54" x2="146" y2="54" stroke="var(--atelier-stone-700)" stroke-width="1.1" stroke-linecap="round" />

          {/* ── Body — main cabinet box ──────────────────────────────── */}
          <rect
            x="18"
            y="54"
            width="124"
            height="178"
            fill="none"
            stroke="var(--atelier-stone-700)"
            stroke-width="1.2"
          />
          {/* Central stile — the divider between the two doors */}
          <line x1="80" y1="58" x2="80" y2="228" stroke="var(--atelier-stone-700)" stroke-width="1" />

          {/* ── Left door ────────────────────────────────────────────── */}
          {/* Outer beaded edge — extra inset line creates the bead detail */}
          <rect x="22" y="58" width="55" height="170" fill="none" stroke="var(--atelier-stone-600)" stroke-width="0.7" />
          {/* Upper raised panel */}
          <rect x="28" y="64" width="43" height="62" fill="none" stroke="var(--atelier-stone-600)" stroke-width="0.9" />
          <rect x="31" y="67" width="37" height="56" fill="none" stroke="var(--atelier-stone-400)" stroke-width="0.5" />
          {/* Cartouche in upper panel — small oval centred */}
          <ellipse cx="49.5" cy="95" rx="9" ry="13" fill="none" stroke="var(--atelier-stone-500)" stroke-width="0.6" />
          <ellipse cx="49.5" cy="95" rx="6.5" ry="10" fill="none" stroke="var(--atelier-stone-400)" stroke-width="0.4" />

          {/* Lower raised panel — taller, no cartouche (restraint) */}
          <rect x="28" y="138" width="43" height="84" fill="none" stroke="var(--atelier-stone-600)" stroke-width="0.9" />
          <rect x="31" y="141" width="37" height="78" fill="none" stroke="var(--atelier-stone-400)" stroke-width="0.5" />

          {/* Brass furniture — escutcheon + ring pull, set on the
              dividing rail between the two panels (the most logical place
              for a real cabinetmaker to put them) */}
          <g>
            {/* Escutcheon backplate */}
            <ellipse cx="72" cy="132" rx="2.5" ry="3.2" fill="var(--atelier-cream)" stroke="var(--atelier-brass-600)" stroke-width="0.5" />
            <line x1="72" y1="131" x2="72" y2="133.5" stroke="var(--atelier-brass-600)" stroke-width="0.5" stroke-linecap="round" />
            {/* Ring pull — circle hanging from escutcheon */}
            <circle cx="72" cy="138" r="2.2" fill="none" stroke="var(--atelier-brass-600)" stroke-width="0.55" />
          </g>

          {/* ── Right door (mirror of left) ──────────────────────────── */}
          <rect x="83" y="58" width="55" height="170" fill="none" stroke="var(--atelier-stone-600)" stroke-width="0.7" />
          <rect x="89" y="64" width="43" height="62" fill="none" stroke="var(--atelier-stone-600)" stroke-width="0.9" />
          <rect x="92" y="67" width="37" height="56" fill="none" stroke="var(--atelier-stone-400)" stroke-width="0.5" />
          <ellipse cx="110.5" cy="95" rx="9" ry="13" fill="none" stroke="var(--atelier-stone-500)" stroke-width="0.6" />
          <ellipse cx="110.5" cy="95" rx="6.5" ry="10" fill="none" stroke="var(--atelier-stone-400)" stroke-width="0.4" />

          <rect x="89" y="138" width="43" height="84" fill="none" stroke="var(--atelier-stone-600)" stroke-width="0.9" />
          <rect x="92" y="141" width="37" height="78" fill="none" stroke="var(--atelier-stone-400)" stroke-width="0.5" />

          <g>
            <ellipse cx="88" cy="132" rx="2.5" ry="3.2" fill="var(--atelier-cream)" stroke="var(--atelier-brass-600)" stroke-width="0.5" />
            <line x1="88" y1="131" x2="88" y2="133.5" stroke="var(--atelier-brass-600)" stroke-width="0.5" stroke-linecap="round" />
            <circle cx="88" cy="138" r="2.2" fill="none" stroke="var(--atelier-brass-600)" stroke-width="0.55" />
          </g>

          {/* ── Apron + plinth ───────────────────────────────────────── */}
          <line x1="14" y1="232" x2="146" y2="232" stroke="var(--atelier-stone-700)" stroke-width="1.1" stroke-linecap="round" />
          <line x1="16" y1="236" x2="144" y2="236" stroke="var(--atelier-stone-500)" stroke-width="0.6" />
          {/* Apron — gentle inward curve at the centre */}
          <path
            d="M 16 240 L 60 240 Q 80 250 100 240 L 144 240"
            fill="none"
            stroke="var(--atelier-stone-700)"
            stroke-width="1"
            stroke-linecap="round"
            stroke-linejoin="round"
          />

          {/* ── Bracket feet ─────────────────────────────────────────── */}
          {/* Two at each end — front and side profile suggested with one
              line each. Splayed slightly outward, classic Regency. */}
          <path d="M 16 240 L 14 258 L 22 258 L 24 240" fill="none" stroke="var(--atelier-stone-700)" stroke-width="0.9" stroke-linejoin="round" />
          <path d="M 136 240 L 138 258 L 146 258 L 144 240" fill="none" stroke="var(--atelier-stone-700)" stroke-width="0.9" stroke-linejoin="round" />

          {/* ── Floor shadow ─────────────────────────────────────────── */}
          <line
            x1="6"
            y1="264"
            x2="154"
            y2="264"
            stroke="var(--atelier-stone-300)"
            stroke-width="0.6"
            stroke-linecap="round"
          />
        </svg>

        {/* Address line — frontispiece form. Three units, increasing
            geography. The real registered office, set as a colophon
            rather than a regulatory disclosure. */}
        <div class="flex flex-col items-center lg:items-end gap-2">
          <span
            aria-hidden="true"
            style="display: inline-block; width: 18px; height: 1.5px; background: var(--atelier-brass-300);"
          />
          <p
            class="text-[10px] uppercase font-medium text-center lg:text-right"
            style="letter-spacing: 0.32em; color: var(--atelier-stone-700); line-height: 1.8;"
          >
            The Long Barn<br />
            Cobham<br />
            Surrey
          </p>
        </div>
      </div>
    </div>

    {/* ── Brass-rule divider ────────────────────────────────────────── */}
    <div
      aria-hidden="true"
      style="height: 1px; background: linear-gradient(to right, transparent, var(--atelier-stone-200) 15%, var(--atelier-stone-200) 85%, transparent);"
    />

    {/* ── Movement 3: Colophon — copyright + statutory disclosure ───── */}
    <div
      class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-4"
      style="padding-top: 2rem; padding-bottom: 2.5rem;"
    >
      {/* Left: copyright + brand attribution */}
      <p
        class="text-[11px] uppercase"
        style="letter-spacing: 0.22em; color: var(--atelier-stone-500); font-weight: 500;"
      >
        &copy; {year} Atelier &middot; A product of Talastron Ltd
      </p>

      {/* Right: statutory disclosure — single quiet paragraph with subtle
          separators. The address line above carries the romance; this
          line carries the legal weight, set as small print. */}
      <p
        class="text-[11px] md:text-right"
        style="color: var(--atelier-stone-400); line-height: 1.7; max-width: 60ch;"
      >
        Talastron Ltd &middot; Registered in England &amp; Wales &middot; Company No. 15464691 &middot; VAT No. GB&nbsp;463&nbsp;5874&nbsp;58<br />
        Registered office: The Long Barn, Cobham Park Road, Cobham, Surrey, KT11&nbsp;3NE
      </p>
    </div>
  </div>
</footer>

<style>
  /* CSS hover/focus replaces inline JS — keyboard-accessible and
     respects reduced-motion preferences without re-implementation. */
  .footer-link {
    color: var(--atelier-stone-600);
    transition: color 200ms ease;
  }
  .footer-link:hover,
  .footer-link:focus-visible {
    color: var(--atelier-stone-900);
  }
</style>
