---
// apps/marketing/src/components/landing/FAQ.astro
//
// Objection-handling, placed just before the closing CTA so the last thing
// a visitor reads before the ask is a reassurance, not a new question.
//
// Native <details>/<summary> accordion — fully accessible and keyboard-
// operable with zero JavaScript. A FAQPage JSON-LD block is emitted inline
// so the answers are eligible for Google rich-snippet results (mirrors the
// SoftwareApplication schema already declared on the home page).
//
// Every answer is grounded in a real, shipped fact:
//   • Intake routes .......... AddItemModal (App.jsx ~2936–3160); see WaysIn
//   • Calendar read-only ..... legal/privacy.mdx
//   • AI not used for training  legal/privacy.mdx
//   • Deletion / portability .. legal/privacy.mdx
//   • 30-day post-cancel hold . legal/privacy.mdx
//   • Pricing / trial ........ pricing.astro (£12/mo · £108/yr · £79 founding)
import { BrassRule } from '@atelier/ui';

const FAQS = [
  {
    q: 'Do I have to photograph everything myself?',
    a: "No. Paste a product link and Atelier pulls the details and image straight from the page. If a shop blocks that, photograph the piece and the Concierge finds the listing for you. You can also add many at once with a closet sweep, scan a care label, or import from a receipt.",
  },
  {
    q: 'How long does it take to set up?',
    a: "Minutes. You don't need to catalogue everything before the Concierge can style you. Add a handful of the pieces you reach for most and it starts composing straight away. The rest can follow in a sitting, or a piece at a time.",
  },
  {
    q: 'How is this different from asking a chatbot what to wear?',
    a: "A general chatbot invents outfits from clothes you may not own. Atelier only styles from your actual wardrobe. It has read every piece you've catalogued, every wear you've logged and every look you've saved, and it checks the day's forecast and your calendar before it answers.",
  },
  {
    q: 'Is my wardrobe and data private?',
    a: "Yes. Your wardrobe, photos and outfits stay in your account. If you connect a calendar it stays read-only, and we never create, edit, delete or store your events. The AI behind the Concierge does not use your content to train its models, and we never sell or share your personal data.",
  },
  {
    q: 'What does it cost, and is there a trial?',
    a: "Every membership begins with a 14-day free trial. After that it is £12 a month, or £108 a year, which works out to about £9 a month. The first hundred founding members pay £79 a year and keep that price for life. Cancel whenever you like.",
  },
  {
    q: 'Can I cancel, and what happens to my data?',
    a: "Cancel anytime from the customer portal. Your studio stays open until the end of the period you have paid for. After that we hold your data for 30 days in case you come back, then delete it. You can also export everything, or delete your account outright, from inside the app whenever you want.",
  },
  {
    q: 'What kind of wardrobe does it work for?',
    a: "Any size, from a thirty-piece capsule to several hundred pieces. Every category is covered, from tailoring and knitwear to trainers, coats, bags and jewellery, so the Concierge dresses you head to toe rather than just tops and bottoms.",
  },
];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: FAQS.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<section
  id="faq"
  style="background: var(--atelier-cream); padding-block: clamp(4.5rem, 9vw, 7rem); padding-inline: var(--atelier-page-padding); border-top: 1px solid rgba(212, 179, 120, 0.18);"
>
  <div class="mx-auto" style="max-width: 760px;">
    {/* Header — centred, matching the Daily Brief / Annual Report treatment */}
    <div class="text-center" style="margin-bottom: clamp(2.5rem, 5vw, 3.5rem);">
      <div class="flex items-center justify-center gap-3 mb-4">
        <BrassRule client:load />
        <p
          class="text-[10px] uppercase font-medium"
          style="letter-spacing: 0.28em; color: var(--atelier-brass-600);"
        >
          Questions
        </p>
        <BrassRule client:load />
      </div>
      <h2
        class="mx-auto"
        style="font-family: var(--atelier-font-display); font-size: clamp(1.875rem, 3.4vw, 2.875rem); line-height: 1.05; letter-spacing: -0.01em; color: var(--atelier-stone-900); max-width: 20ch;"
      >
        Before you <em style="font-weight: 400;">take the keys</em>.
      </h2>
    </div>

    {/* Accordion — native <details>; first item open by default so the
        section never reads as an empty stack of closed bars. */}
    <div style="border-top: 1px solid var(--atelier-stone-200);">
      {FAQS.map((f, i) => (
        <details class="faq-item" open={i === 0}>
          <summary class="faq-summary">
            <span class="faq-question">{f.q}</span>
            <span class="faq-marker" aria-hidden="true"></span>
          </summary>
          <div class="faq-answer">
            <p>{f.a}</p>
          </div>
        </details>
      ))}
    </div>

    {/* Still-curious line → support email. Gives the undecided a low-stakes
        next step that isn't the checkout. */}
    <p
      class="text-center mt-10"
      style="font-family: var(--atelier-font-display); font-style: italic; font-size: 0.9375rem; color: var(--atelier-stone-500);"
    >
      Still deciding? Write to us at{' '}
      <a
        href="mailto:contact@myatelier.style"
        style="color: var(--atelier-brass-600); text-decoration: none; border-bottom: 1px solid var(--atelier-brass-300);"
      >
        contact@myatelier.style
      </a>
      .
    </p>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
</section>

<style>
  .faq-item {
    border-bottom: 1px solid var(--atelier-stone-200);
  }

  .faq-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: clamp(1.1rem, 2vw, 1.5rem) 0;
    cursor: pointer;
    list-style: none;
    outline-offset: 4px;
  }
  .faq-summary::-webkit-details-marker {
    display: none;
  }

  .faq-question {
    font-family: var(--atelier-font-display);
    font-size: clamp(1.0625rem, 1.6vw, 1.3125rem);
    line-height: 1.3;
    /* stone-800: these are primary reading lines and must clear WCAG AA. */
    color: var(--atelier-stone-800, #292524);
    transition: color 200ms ease;
  }
  .faq-summary:hover .faq-question {
    color: var(--atelier-stone-900);
  }

  /* Plus → minus marker, drawn in brass. */
  .faq-marker {
    position: relative;
    flex-shrink: 0;
    width: 14px;
    height: 14px;
  }
  .faq-marker::before,
  .faq-marker::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    background: var(--atelier-brass-600);
    transform: translate(-50%, -50%);
    transition: transform 260ms cubic-bezier(0.22, 1, 0.36, 1), opacity 260ms ease;
  }
  .faq-marker::before {
    width: 14px;
    height: 1.5px;
  }
  .faq-marker::after {
    width: 1.5px;
    height: 14px;
  }
  .faq-item[open] .faq-marker::after {
    transform: translate(-50%, -50%) scaleY(0);
    opacity: 0;
  }

  .faq-answer {
    padding: 0 0 clamp(1.25rem, 2.5vw, 1.75rem);
    max-width: 62ch;
  }
  .faq-answer p {
    font-size: clamp(0.9375rem, 1.1vw, 1.0625rem);
    line-height: 1.7;
    color: var(--atelier-stone-600);
  }

  @media (prefers-reduced-motion: no-preference) {
    .faq-item[open] .faq-answer {
      animation: faq-answer-in 320ms cubic-bezier(0.22, 1, 0.36, 1);
    }
    @keyframes faq-answer-in {
      from { opacity: 0; transform: translateY(-0.25rem); }
      to { opacity: 1; transform: translateY(0); }
    }
  }
</style>

<script>
  /* Accordion behaviour — opening one row closes the others. Progressive
     enhancement: without JS every row is independently toggleable. */
  const items = Array.from(document.querySelectorAll('#faq .faq-item')) as HTMLDetailsElement[];
  items.forEach((item) => {
    item.addEventListener('toggle', () => {
      if (item.open) {
        items.forEach((other) => {
          if (other !== item) other.open = false;
        });
      }
    });
  });
</script>
