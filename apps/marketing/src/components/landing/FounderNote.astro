---
// apps/marketing/src/components/landing/FounderNote.astro
//
// A compact founder moment for the home page. With no members to quote yet,
// the honest credibility Atelier does have is a real, named founder who built
// the thing for herself first. This band surfaces a thread of that story and
// links to the full note on /about.
//
// Everything here is drawn verbatim from the founder section of /about
// ("The Maker"): the photo at /about/sibylle.jpg, the name, the barn in
// Surrey, and the closing line of her origin paragraph. Nothing is invented.
//
// Framed with the same vellum vocabulary as the founder photo on /about and
// the Founding card on /pricing (white matte, brass border-rule, brass corner
// ornaments) so the brand mark frames her consistently across the site.
import { BrassRule } from '@atelier/ui';
---

<section
  id="founder-note"
  style="background: var(--atelier-stone-50); padding-block: clamp(4rem, 8vw, 6rem); padding-inline: var(--atelier-page-padding); border-top: 1px solid rgba(212, 179, 120, 0.18);"
>
  <div
    class="mx-auto flex flex-col items-center text-center"
    style="max-width: 640px;"
  >
    {/* Eyebrow — matches the "The Maker" section on /about */}
    <div class="flex items-center justify-center gap-3 mb-8">
      <BrassRule client:load />
      <p
        class="text-[10px] uppercase font-medium"
        style="letter-spacing: 0.28em; color: var(--atelier-brass-600);"
      >
        From the founder
      </p>
      <BrassRule client:load />
    </div>

    {/* Framed photo — small vellum card, B&W, same treatment as /about */}
    <figure style="margin: 0 0 clamp(1.75rem, 3vw, 2.25rem);">
      <div
        style="position: relative; padding: 10px; background: #ffffff; border: 1px solid var(--atelier-stone-200); border-radius: 4px; box-shadow: 0 24px 48px -24px rgba(28, 25, 23, 0.22), 0 6px 16px -8px rgba(28, 25, 23, 0.08); width: clamp(96px, 22vw, 120px);"
      >
        <img
          src="/about/sibylle.jpg"
          alt="Sibylle Möller-Sherwood, founder of Atelier"
          loading="lazy"
          width="120"
          height="150"
          style="display: block; width: 100%; height: auto; aspect-ratio: 4 / 5; object-fit: cover; filter: grayscale(0.9) contrast(1.05); border-radius: 2px; position: relative; z-index: 0;"
        />
        <div
          aria-hidden="true"
          style="position: absolute; inset: 5px; border: 1px solid rgba(212, 179, 120, 0.4); pointer-events: none; border-radius: 2px; z-index: 1;"
        />
        <span aria-hidden="true" style="position: absolute; width: 4px; height: 4px; background: var(--atelier-brass-600); border-radius: 1px; top: 2px; left: 2px; z-index: 2;" />
        <span aria-hidden="true" style="position: absolute; width: 4px; height: 4px; background: var(--atelier-brass-600); border-radius: 1px; top: 2px; right: 2px; z-index: 2;" />
        <span aria-hidden="true" style="position: absolute; width: 4px; height: 4px; background: var(--atelier-brass-600); border-radius: 1px; bottom: 2px; left: 2px; z-index: 2;" />
        <span aria-hidden="true" style="position: absolute; width: 4px; height: 4px; background: var(--atelier-brass-600); border-radius: 1px; bottom: 2px; right: 2px; z-index: 2;" />
      </div>
    </figure>

    {/* The line — drawn verbatim from her origin paragraph on /about. */}
    <blockquote
      style="margin: 0; font-family: var(--atelier-font-display); font-style: italic; font-size: clamp(1.25rem, 2.4vw, 1.75rem); line-height: 1.4; letter-spacing: -0.005em; color: var(--atelier-stone-700); max-width: 24ch;"
    >
      I built it for myself first. Then for friends. Now for anyone who, like
      me, wants less, used better.
    </blockquote>

    {/* Attribution — real name, real place */}
    <p
      class="mt-7 text-[11px] uppercase"
      style="letter-spacing: 0.24em; color: var(--atelier-stone-500); font-weight: 600;"
    >
      Sibylle Möller-Sherwood
    </p>
    <p
      class="mt-1.5 text-[11px]"
      style="color: var(--atelier-stone-400); font-style: italic; font-family: var(--atelier-font-display);"
    >
      Founder · one person, one barn, in Surrey
    </p>

    {/* Link to the full note */}
    <a
      href="/about"
      class="founder-note-link mt-8 inline-flex items-center gap-2 text-[10px] uppercase font-semibold"
      style="letter-spacing: 0.24em; color: var(--atelier-brass-600);"
    >
      Read her note
      <span aria-hidden="true">→</span>
    </a>
  </div>
</section>

{/* .founder-note-link styles live in src/styles/global.css so they ship in
    the main linked stylesheet rather than a per-page inline block. */}
