---
// apps/marketing/src/pages/index.astro
// Each landing section sized to fit a single viewport without scrolling.
// Hero + auto-shuffling outfit row, then Concierge spotlight (top-aligned
// copy + demo), then Suggest-a-Look spotlight (centered, tight copy).

import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Philosophy from '../components/Philosophy.astro';
import ClosingMasthead from '../components/ClosingMasthead.astro';
import { Hero } from '../components/landing/Hero.jsx';
import { ConciergeReel } from '../components/landing/ConciergeReel.jsx';
import { InsideAtelier } from '../components/landing/InsideAtelier.jsx';
import { WhatAtelierDoes } from '../components/landing/WhatAtelierDoes.jsx';
import { InvestmentLens } from '../components/landing/InvestmentLens.jsx';
import WaysIn from '../components/landing/WaysIn.astro';
import ShareLooks from '../components/landing/ShareLooks.astro';
import FounderNote from '../components/landing/FounderNote.astro';
import FAQ from '../components/landing/FAQ.astro';
import JournalRail from '../components/JournalRail.astro';
import { BrassRule } from '@atelier/ui';
import { SITE, EDIT_URL } from '../config.ts';

// SoftwareApplication structured data — tells Google this page represents
// a piece of software, which unlocks rich snippets (ratings, price, screen-
// shots) when the brand is searched for. We declare the founding-member
// price (£79/yr) here as the lower of the two tiers; the public price is
// surfaced on /pricing where a more detailed Product schema would belong.
const softwareLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: SITE.name,
  url: SITE.url,
  applicationCategory: 'LifestyleApplication',
  operatingSystem: 'Web',
  description: 'A private digital wardrobe and AI stylist. Capture your pieces, log wears, and have an AI compose outfits from what you already own.',
  offers: {
    '@type': 'Offer',
    price: '79',
    priceCurrency: 'GBP',
    url: `${SITE.url}/pricing`,
    availability: 'https://schema.org/InStock',
  },
};
---

<Base
  title="Atelier — An AI stylist that knows your wardrobe"
  jsonLd={softwareLd}
>
  <Nav />
  <main>
    {/* ── Hero: the Suggest-a-Look daily brief ──────────────────────── */}
    <Hero client:load />

    {/* ── The Concierge at work — a live conversation showcase: a question
        types into the chat panel and the depth carousel below shuffles
        through five real interactions (what to wear · pack a trip · worn
        least · cost-per-wear · style manifesto). Consolidates what used to be
        three separate mid-page demos. ── */}
    <ConciergeReel client:load />

    {/* ── What Atelier does — states the app's purpose plainly (header →
        four-capability grid: Catalogue / Log / Style / Track) for the Google
        OAuth homepage review, in the site's own editorial design language. ── */}
    <section
      id="what-atelier-does"
      style="background: var(--atelier-cream); padding-block: clamp(4rem, 8vw, 7rem); padding-inline: var(--atelier-page-padding); border-top: 1px solid rgba(212, 179, 120, 0.18);"
    >
      <div class="mx-auto" style="max-width: var(--atelier-content-max);">
        {/* Header */}
        <div style="max-width: 640px;">
          <div class="flex items-center gap-3 mb-5">
            <BrassRule client:load />
            <p class="text-[10px] uppercase font-medium" style="letter-spacing: 0.28em; color: var(--atelier-brass-text);">
              What Atelier does
            </p>
          </div>
          <h2
            style="font-family: var(--atelier-font-display); font-size: clamp(2rem, 3.6vw, 3.25rem); line-height: 1.05; letter-spacing: -0.01em; color: var(--atelier-stone-900); margin-bottom: 1.5rem;"
          >
            A digital wardrobe, <em style="font-weight: 400;">and a stylist</em> who's read every piece.
          </h2>
          <p style="font-size: clamp(1rem, 1.15vw, 1.125rem); line-height: 1.7; color: var(--atelier-stone-600); max-width: 56ch;">
            Atelier is a personal styling app. You catalogue the clothes you already own, log what
            you wear, and an AI stylist — the Concierge — composes head-to-toe outfits from
            <em>your own</em> wardrobe.
          </p>
        </div>

        {/* Capabilities — the four statements as a tabbed showcase whose
            stage renders truthful mini-vignettes of the actual studio.
            All four claims remain permanently in the DOM (the tab index IS
            the copy), preserving the plain-text purpose statement the
            Google OAuth homepage review requires. */}
        <div style="margin-top: clamp(2.75rem, 5vw, 4.5rem);">
          <WhatAtelierDoes client:visible />
        </div>
      </div>
    </section>

    {/* ── Filling the wardrobe — answers the "must I photograph a hundred
        things by hand?" objection right where it forms (just after the
        Catalogue claim), by surfacing the real AI-assisted intake routes:
        paste a link · snap a photo · sweep the closet. ── */}
    <WaysIn />

    {/* ── Inside Atelier — interactive tour of the real app surfaces
        (Wardrobe / Styling Studio / Lookbook), desktop + mobile frames.
        Shows the homepage visitor exactly what they get on sign-in. ── */}
    <InsideAtelier client:load />

    {/* ── The Investment Lens — stats spread ────────────────────────── */}
    <InvestmentLens client:visible />

    {/* ── Share a look — surfaces the real sharing feature (share a look or
        a whole lookbook as a public link that opens without sign-in). Sits
        after the compose/pack features and before the reflective content. ── */}
    <ShareLooks />

    {/* ── Section 6: Journal rail — three latest essays ─────────────── */}
    <JournalRail />

    {/* ── From the founder — honest credibility in place of testimonials
        (no members to quote yet): a real, named founder and a thread of
        her story, linking to the full note on /about. ── */}
    <FounderNote />

    {/* ── FAQ — objection-handling immediately before the ask, so the last
        thing read before the CTA is a reassurance. Native <details>
        accordion + FAQPage JSON-LD for rich-snippet eligibility. ── */}
    <FAQ />

    {/* ── Closing CTA ────────────────────────────────────────────────── */}
    <Philosophy />

    {/* Site-wide closing masthead — same brand imprint that closes
        /about, /pricing, and both journal pages. */}
    <ClosingMasthead />
  </main>
  <Footer />
</Base>
