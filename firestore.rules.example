rules_version = '2';

// ─── FORKS: copy this file to firestore.rules and edit the owner emails ──
// `cp firestore.rules.example firestore.rules` then replace the placeholder
// emails below with your own Google account email. The list MUST match
// VITE_OWNER_EMAILS in your .env.local.
// firestore.rules itself is gitignored so each developer maintains their own.

service cloud.firestore {
  match /databases/{database}/documents {
    // Permanent owners — never lose access even if `/allowlist/...` is empty.
    // Owners can invite/revoke others from inside the app.
    function isOwner() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'replace-with-your-email@example.com'
        ];
    }

    // Invited friends — owners manage this from inside the app.
    function isInvited() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && exists(/databases/$(database)/documents/allowlist/$(request.auth.token.email));
    }

    function canSignIn() {
      return isOwner() || isInvited();
    }

    // Each user (owner or invited) gets a private subtree at /users/{uid}/...
    // Cross-user access is denied.
    match /users/{uid}/{document=**} {
      allow read, write: if canSignIn() && request.auth.uid == uid;
    }

    // Allowlist: owners can read & manage; an invited user can read just their
    // own entry (so the app can confirm "yes, you're in").
    match /allowlist/{email} {
      allow read: if isOwner() || (request.auth != null && request.auth.token.email == email);
      allow write: if isOwner();
    }

    // Public shared looks: anyone with the link can READ. Only signed-in users
    // can create. Share docs embed snapshots so they stay viewable even if the
    // original is later edited or deleted.
    match /public/{shareId} {
      allow read: if true;
      allow create, update: if canSignIn();
      allow delete: if canSignIn();
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
